
/target/
**/*.rs.bk

# Output files from binaries (generated, not checked in)
*.csv
*.svg

# ...but telemetry-import test fixtures ARE checked in (they are tiny,
# hand-written, and required by the apex-correlate importer tests).
!crates/apex-correlate/tests/fixtures/*.csv

# TUMFTM-derived local track imports (LGPL-3.0 data, not redistributed — see
# tracks/README.md). Ignore ALL imported track JSON, re-including only the two
# committed synthetic sample tracks.
/tracks/*.json
!/tracks/test_circle.json
!/tracks/oval_simple.json
/tracks/*.tumftm.json

# --- Measured telemetry (apex-correlate / FastF1 bridge) ---
# Derived telemetry CSVs and the FastF1 HTTP cache stay LOCAL for now. FastF1
# serves official F1/FOM timing data whose redistribution terms we are not
# taking a position on yet, so we do NOT commit derived telemetry. Committing
# curated/derived summaries is a later, deliberate decision (see
# telemetry/README.md). `*.csv` already covers the CSVs; these are explicit for
# clarity and to also ignore the binary cache directory.
/telemetry/.fastf1_cache/
/telemetry/*.csv
# Alignment sidecars (derived from measured telemetry; stay local).
/telemetry/*.align.toml
# Correlation report output (report.md + SVGs) — derived from measured data,
# stays local. The hand-curated summary in docs/validation/ IS committed.
/telemetry/correlation_out/
/telemetry/**/report.md
# Campaign output (per-circuit correlate dirs + summary.json) — derived, local.
/telemetry/campaign/

# Independent .ld verification reader (ldparser, GPL-3.0) is fetched on demand
# to this local cache by tools/verify_ld.py — never vendored/committed (license
# incompatible with this repo's MIT/Apache).
/tools/.ldparser_cache/
/tools/__pycache__/

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Internal planning docs
APEX-14_PROJECT_PLAN.md
PROJECT_REPORT.md

# Local scratch / manual test scripts
test_*.py

# Python bytecode cache
__pycache__/
*.pyc

# ML training artifacts (generated, not checked in)
*.safetensors
*.safetensors.meta.json
training_data.json
